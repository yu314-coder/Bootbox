+// mountAndroidData gives Android a real ext4 /data filesystem. The generic
+// container overlay uses a tmpfs upper layer, and tmpfs cannot store the
+// user.serial xattrs Android uses to validate user and application data. QEMU
+// supplies the thin-provisioned userdata disk as the second virtio drive.
+func mountAndroidData() error {
+	const (
+		root       = "/run/rootfs"
+		data       = "/run/rootfs/data"
+		dataDevice = "/dev/vdb"
+	)
+	if _, err := os.Stat(filepath.Join(root, "system", "build.prop")); err != nil {
+		if errors.Is(err, os.ErrNotExist) {
+			return nil
+		}
+		return fmt.Errorf("cannot inspect Android rootfs: %w", err)
+	}
+	if _, err := os.Stat(dataDevice); err != nil {
+		return fmt.Errorf("Android userdata disk %q is unavailable: %w", dataDevice, err)
+	}
+	if err := os.MkdirAll(data, 0771); err != nil {
+		return fmt.Errorf("cannot create Android data mountpoint: %w", err)
+	}
+	flags := uintptr(syscall.MS_NOATIME | syscall.MS_NODIRATIME)
+	if err := syscall.Mount(dataDevice, data, "ext4", flags, "data=writeback,commit=30"); err != nil {
+		return fmt.Errorf("cannot mount Android userdata disk: %w", err)
+	}
+	return nil
+}
+
+// rootfsEtcFilePath resolves Android-style absolute /etc symlinks inside the
+// container root instead of against the tiny VM init filesystem. For example,
+// Android's /etc -> /system/etc must map to /run/rootfs/system/etc.
+func rootfsEtcFilePath(name string) (string, error) {
+	const root = "/run/rootfs"
+	etc := filepath.Join(root, "etc")
+	if target, err := os.Readlink(etc); err == nil {
+		if filepath.IsAbs(target) {
+			etc = filepath.Join(root, strings.TrimPrefix(target, "/"))
+		} else {
+			etc = filepath.Join(filepath.Dir(etc), target)
+		}
+	} else if !errors.Is(err, syscall.EINVAL) {
+		return "", fmt.Errorf("cannot inspect rootfs /etc: %w", err)
+	}
+	dst := filepath.Clean(filepath.Join(etc, name))
+	rel, err := filepath.Rel(root, dst)
+	if err != nil || rel == ".." || strings.HasPrefix(rel, ".."+string(filepath.Separator)) {
+		return "", fmt.Errorf("rootfs /etc target escapes container root: %q", dst)
+	}
+	return dst, nil
+}
+
+// ensureAndroidDevices creates misc-device nodes that a devtmpfs mounted before
+// the Binder drivers finish registering can miss. Their dynamic minors are read
+// from /proc/misc rather than assumed.
+func ensureAndroidDevices() error {
+	data, err := os.ReadFile("/proc/misc")
+	if err != nil {
+		return fmt.Errorf("cannot read misc devices: %w", err)
+	}
+	minors := make(map[string]int)
+	for _, line := range strings.Split(string(data), "\n") {
+		var minor int
+		var name string
+		if _, err := fmt.Sscanf(line, "%d %s", &minor, &name); err == nil {
+			minors[name] = minor
+		}
+	}
+	for _, name := range []string{"binder", "hwbinder", "vndbinder", "uinput"} {
+		path := filepath.Join("/dev", name)
+		if _, err := os.Stat(path); err == nil {
+			// Static Binder nodes arrive from devtmpfs as 0600. Android's
+			// servicemanager and HAL managers run as uid 1000 and ReDroid's
+			// ueventd cannot chmod a node that is later bind-mounted into the
+			// container, so set the standard Android permission here.
+			if err := os.Chmod(path, 0666); err != nil {
+				return fmt.Errorf("cannot set Android device permissions on %q: %w", path, err)
+			}
+			continue
+		} else if !errors.Is(err, os.ErrNotExist) {
+			return fmt.Errorf("cannot inspect Android device %q: %w", path, err)
+		}
+		minor, ok := minors[name]
+		if !ok {
+			return fmt.Errorf("Android Binder device %q is not registered in /proc/misc", name)
+		}
+		if err := syscall.Mknod(path, syscall.S_IFCHR|0666, (10<<8)|minor); err != nil {
+			return fmt.Errorf("cannot create Android device %q: %w", path, err)
+		}
+		if err := os.Chmod(path, 0666); err != nil {
+			return fmt.Errorf("cannot set Android device permissions on %q: %w", path, err)
+		}
+	}
+	return nil
+}
