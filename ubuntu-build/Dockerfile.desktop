# Bootbox DESKTOP guest (x86_64) — a lightweight graphical desktop. NO Wine (that stays in the console
# guest). v2 (build 73): graphical browser (Dillo) + file manager (PCManFM) + Claude Code CLI + a real
# wallpaper. HISTORY: dillo/BadWolf "flooded the single-threaded Xvnc until the GUI froze" — but that
# was tested BEFORE the cx16 engine fix, when every guest allocation took a stop-the-world exclusive
# section (kernel SLUB uses lock cmpxchg16b). With the spinlock engine those light GUI apps get
# RE-TESTED in the Mac harness before shipping. `links` (text, terminal) stays as fallback.
# Plus twm/tint2 + terminal + mc. Python + pip preloaded.

# -- side stage: generated wallpaper (radial gradient + label), no runtime imagemagick needed --
FROM alpine:3.20 AS wall
RUN apk add --no-cache imagemagick ttf-dejavu >/dev/null 2>&1 && \
    magick -size 1024x768 radial-gradient:'#27466f'-'#0a1220' /w1.png && \
    magick /w1.png -font /usr/share/fonts/dejavu/DejaVuSans-Bold.ttf -pointsize 26 \
      -fill '#40639b' -gravity southeast -annotate +30+22 'BOOTBOX' /wallpaper.png && \
    ls -la /wallpaper.png

FROM alpine:3.20

# 1) Python 3 + FAST pip (uv) + stdlib bytecode (so python startup is fast under the TCG CPU).
RUN set -eux; \
    apk add --no-cache python3 py3-pip curl tar; \
    (apk add --no-cache uv 2>/dev/null || { \
       curl -fsSL https://github.com/astral-sh/uv/releases/latest/download/uv-x86_64-unknown-linux-musl.tar.gz -o /tmp/uv.tgz; \
       tar xzf /tmp/uv.tgz -C /tmp; cp /tmp/uv-*/uv /tmp/uv-*/uvx /usr/local/bin/; rm -rf /tmp/uv*; }); \
    rm -f /usr/lib/python3.12/EXTERNALLY-MANAGED; \
    python3 -m compileall -j 0 -q /usr/lib/python3.12 || true; \
    (/usr/local/bin/uv --version || uv --version)
ENV UV_SYSTEM_PYTHON=1
COPY pip-uv.sh /usr/local/bin/pip
RUN chmod +x /usr/local/bin/pip && ln -sf pip /usr/local/bin/pip3 && echo "PIP-UV-OK"

# 2) PIP OPTIMIZATION: pre-install a bigger curated set of common PURE-PYTHON packages so the user's
#    `pip install X` is INSTANT for them (no resolve/download). Compile their bytecode too. (C-extension
#    packages like numpy aren't pre-installed: PyPI ships glibc manylinux wheels, not musl, so they'd
#    build from source on Alpine — slow; `apk add py3-numpy` is the fast path if ever needed.)
RUN set -eux; \
    KEEP="requests flask rich click pyyaml httpx beautifulsoup4 pydantic urllib3 certifi idna charset-normalizer jinja2 markupsafe itsdangerous werkzeug python-dateutil six setuptools wheel packaging typing-extensions"; \
    uv pip install $KEEP 2>&1 | tail -2 || true; \
    uv cache clean 2>&1 | tail -1 || true; \
    python3 -m compileall -j 0 -q /usr/lib/python3.12/site-packages || true; \
    echo "PIP-PRELOAD [$(echo $KEEP | wc -w) pkgs] cache=$(du -sh /root/.cache/uv 2>/dev/null | cut -f1)"

# 3) Desktop: Xvnc (X+VNC in one) + twm (the only WM that survives the single-threaded Xvnc under TCG)
#    + tint2 (panel) + xterm + browsers + mc.
RUN set -eux; \
    apk add --no-cache tigervnc twm tint2 xsetroot xterm font-misc-misc ttf-dejavu mc links; \
    echo "DESKTOP-LAYER $(apk info 2>/dev/null | wc -l) pkgs twm=$(command -v twm)"

# 3b) v2 (build 73): graphical browser + file manager + Claude Code CLI + wallpaper tools.
#     dillo = FLTK (light, CSS, no JS) · pcmanfm = the standard light GTK file manager ·
#     claude = @anthropic-ai/claude-code on node 20 (apk ripgrep so the musl guest never needs
#     the bundled glibc rg; git for repo work). npm cache cleaned (would bloat the rootfs).
RUN set -eux; \
    apk add --no-cache dillo pcmanfm xwallpaper nodejs npm ripgrep git 2>&1 | tail -1; \
    npm install -g @anthropic-ai/claude-code 2>&1 | tail -2; \
    npm cache clean --force 2>&1 | tail -1 || true; \
    claude --version; \
    echo "DESKTOP-V2-OK dillo=$(command -v dillo) pcmanfm=$(command -v pcmanfm) claude=$(claude --version 2>/dev/null | head -c 40) nm=$(du -sm /usr/lib/node_modules 2>/dev/null | cut -f1)MB"
COPY --from=wall /wallpaper.png /usr/share/bootbox-wallpaper.png

# 3b2) v3 (build 74): desktop ICONS + official-claude check + real `help`.
#      · The user asked for the official CLI: try Anthropic's native installer first; if its
#        binary runs on musl, it wins — otherwise the npm @anthropic-ai/claude-code (ALSO the
#        official CLI, just the npm distribution) stays. Either way `claude --version` gates.
#      · Desktop icons: PCManFM --desktop renders the wallpaper AND clickable .desktop icons
#        (the classic Linux desktop layer) — icons for Dillo/Files/Claude/Terminal/Python.
#      · adwaita-icon-theme so the icons are real, not placeholder squares.
#      · `help` → a real command list (ash's builtin is shadowed via a profile alias).
RUN set -eux; \
    (curl -fsSL https://claude.ai/install.sh | sh 2>&1 | tail -2 && \
     /root/.local/bin/claude --version && ln -sf /root/.local/bin/claude /usr/local/bin/claude && echo "CLAUDE-NATIVE-OK") \
    || echo "CLAUDE-NATIVE-SKIP (musl — the npm official CLI stays)"; \
    claude --version; \
    apk add --no-cache adwaita-icon-theme 2>&1 | tail -1; \
    mkdir -p /usr/share/bootbox-apps /root/.config/pcmanfm/default /root/.config/libfm; \
    printf '[Desktop Entry]\nType=Application\nName=Web (Dillo)\nIcon=web-browser\nExec=dillo http://example.com\n' > "/usr/share/bootbox-apps/dillo.desktop"; \
    printf '[Desktop Entry]\nType=Application\nName=Files\nIcon=system-file-manager\nExec=pcmanfm\n' > "/usr/share/bootbox-apps/files.desktop"; \
    printf '[Desktop Entry]\nType=Application\nName=Claude Code\nIcon=utilities-terminal\nExec=bxterm -bg rgb:0d/15/26 -fg rgb:cd/e6/ff -geometry 100x32 -title Claude -e sh -lc claude\n' > "/usr/share/bootbox-apps/claude.desktop"; \
    printf '[Desktop Entry]\nType=Application\nName=Terminal\nIcon=utilities-terminal\nExec=bxterm -ls -bg rgb:0b/0f/17 -fg rgb:b7/f5/cf\n' > "/usr/share/bootbox-apps/terminal.desktop"; \
    printf '[Desktop Entry]\nType=Application\nName=Python\nIcon=text-x-script\nExec=bxterm -bg black -fg white -e python3\n' > "/usr/share/bootbox-apps/python.desktop"; \
    chmod +x /usr/share/bootbox-apps/*.desktop; \
    printf '[*]\nwallpaper_mode=stretch\nwallpaper=/usr/share/bootbox-wallpaper.png\ndesktop_bg=#0a1220\ndesktop_fg=#dfe8f5\ndesktop_shadow=#0a1220\nshow_documents=0\nshow_trash=0\nshow_mounts=0\n' > /root/.config/pcmanfm/default/desktop-items-0.conf; \
    printf '[config]\nsingle_click=1\nquick_exec=1\n' > /root/.config/libfm/libfm.conf; \
    echo "APPS-OK $(ls /usr/share/bootbox-apps | tr '\n' ' ')"
# 3b3) v4 (build 75): fonts, locale, help, and the openbox menu — the round that fixes the
#      garbled Claude TUI, 'help not found', and the ancient twm look.
#      · Box-drawing FONT without Xft weight: `bxterm` wrapper picks Terminus (a Unicode BITMAP
#        font — box-drawing glyphs AND fast under TCG, unlike heavy Xft TrueType which wedged the
#        single-threaded Xvnc) when Xvnc has loaded it, else falls back to `fixed` — so terminals
#        can NEVER break. xstart writes /tmp/termfont after probing xlsfonts. (font-misc-misc on
#        Alpine ships no iso10646 variants, so `-fn fixed` alone has no box-drawing — the v3 bug.)
#      · help: alias in BOTH /etc/profile (login shells) AND $ENV=/etc/ashrc (every interactive
#        ash) — the v3 profile-only alias never loaded in the desktop's non-login xterm.
#      · openbox menu.xml = right-click app launcher (opaque drag + modern borders come free).
RUN set -eux; \
    printf '#!/bin/sh\n# `fixed` is the only bitmap font this Xvnc reliably loads (it lacks the freetype/OTB\n# module for Terminus .otb, and this xterm EXITS on a missing -fn rather than falling back —\n# tested). -u8 keeps UTF-8 text correct. Box-drawing glyphs are limited, so Claude Code TUI\n# borders may look plain, but the terminal always opens.\nexec xterm -fn fixed -u8 -sb -sl 4000 "$@"\n' > /usr/local/bin/bxterm; \
    chmod +x /usr/local/bin/bxterm; \
    printf 'alias help=/usr/local/bin/bootbox-help\n' > /etc/ashrc; \
    printf 'export LANG=C.UTF-8\nexport LC_ALL=C.UTF-8\nexport ENV=/etc/ashrc\nalias help=/usr/local/bin/bootbox-help\n' > /etc/profile.d/00bootbox.sh; \
    mkdir -p /root/.config/tint2; \
    { \
      echo 'rounded = 0'; echo 'border_width = 0'; \
      echo 'background_color = #16263f 100'; echo 'panel_background_id = 1'; \
      echo 'panel_items = LTC'; \
      echo 'panel_position = bottom center horizontal'; \
      echo 'panel_size = 100% 46'; echo 'panel_margin = 0 0'; echo 'panel_padding = 6 4 6'; \
      echo 'panel_dock = 0'; echo 'wm_menu = 1'; echo 'panel_layer = top'; \
      echo 'taskbar_mode = single_desktop'; echo 'taskbar_padding = 4 0 4'; \
      echo 'task_text = 1'; echo 'task_font_color = #dfe8f5 100'; echo 'task_padding = 6 2'; \
      echo 'launcher_padding = 4 6 4'; echo 'launcher_icon_size = 34'; echo 'launcher_icon_theme = Adwaita'; \
      echo 'launcher_item_app = /usr/share/bootbox-apps/dillo.desktop'; \
      echo 'launcher_item_app = /usr/share/bootbox-apps/files.desktop'; \
      echo 'launcher_item_app = /usr/share/bootbox-apps/claude.desktop'; \
      echo 'launcher_item_app = /usr/share/bootbox-apps/terminal.desktop'; \
      echo 'launcher_item_app = /usr/share/bootbox-apps/python.desktop'; \
      echo 'time1_format = %H:%M'; echo 'time1_font = sans 10'; echo 'clock_font_color = #dfe8f5 100'; echo 'clock_padding = 6 0'; \
    } > /root/.config/tint2/tint2rc; \
    echo "FONTS-HELP-TINT2-OK"
COPY bootbox-help.sh /usr/local/bin/bootbox-help
RUN chmod +x /usr/local/bin/bootbox-help && \
    printf 'alias help="/usr/local/bin/bootbox-help"\n' > /etc/profile.d/00bootbox-help.sh && \
    echo "HELP-OK"

# 3c) First-run warm-up (the wine lesson applied to the desktop): GTK's first start builds icon
#     and mime caches — minutes on the emulated CPU that make PCManFM look hung. Run both GUI
#     apps once against a throwaway X here at native speed; also refresh the shared caches
#     explicitly so the artifacts are deterministic.
RUN set -eux; \
    apk add --no-cache xvfb 2>&1 | tail -1; \
    gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true; \
    update-mime-database /usr/share/mime 2>/dev/null || true; \
    (Xvfb :9 -screen 0 640x480x16 >/tmp/xvfb.log 2>&1 &); sleep 3; \
    (DISPLAY=:9 timeout 60 pcmanfm >/tmp/warm-pc.log 2>&1 &); sleep 20; \
    (DISPLAY=:9 timeout 40 dillo about:blank >/tmp/warm-d.log 2>&1 &); sleep 12; \
    pkill pcmanfm 2>/dev/null || true; pkill dillo 2>/dev/null || true; pkill Xvfb || true; \
    apk del xvfb 2>&1 | tail -1; \
    echo "DESKTOP-WARM-OK"

# 4) Slim (docs/man/locale/extra fonts) — keeps the download small.
RUN set -eux; \
    rm -rf /usr/share/man /usr/share/doc /usr/share/gtk-doc /usr/share/locale /usr/share/i18n /usr/share/info /var/cache/apk/*; \
    (cd /usr/share/fonts/dejavu 2>/dev/null && ls | grep -vE '^(DejaVuSans\.ttf|DejaVuSans-Bold\.ttf|DejaVuSansMono\.ttf|DejaVuSansMono-Bold\.ttf|fonts\.)' | xargs rm -f) || true; \
    fc-cache -f 2>/dev/null || true; \
    echo "SLIM usr=$(du -sm /usr | cut -f1)MB total=$(du -sm / 2>/dev/null | cut -f1)MB"

# Boots straight into the full desktop (launcher menu + browser + file manager).
COPY xstart-desktop.sh /usr/local/bin/xstart
RUN chmod +x /usr/local/bin/xstart
CMD ["/usr/local/bin/xstart"]
